module RCon
  class Client
    VERSION: String

    class Error < StandardError
    end

    class AuthenticationError < Error
    end

    class ConnectionError < Error
    end

    DEFAULT_PORT: Integer

    def initialize: (String host, ?Integer port, password: String, ?sentinel_command: String) -> void
    def self.open: (String host, ?Integer port, password: String, ?sentinel_command: String) -> Client
                 | (String host, ?Integer port, password: String, ?sentinel_command: String) { (Client) -> void } -> void
    def connect: () -> self
    def execute: (String command) -> String
    def close: () -> void
    def connected?: () -> bool

    private

    def next_id: () -> Integer
    def authenticate: () -> void
    def reader_loop: () -> void
    def dispatch: (Packet packet) -> void
  end
end
